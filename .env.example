# Verified against OpenClaw docs on 2026-04-06.
# Latest checked release on that date: 2026.4.5

OPENCLAW_CONTAINER=openclaw
OPENCLAW_PODMAN_CONTAINER=openclaw
OPENCLAW_PODMAN_IMAGE=
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.5

OPENCLAW_PODMAN_GATEWAY_HOST_PORT=18789
OPENCLAW_PODMAN_BRIDGE_HOST_PORT=18790
OPENCLAW_PODMAN_BOARD_HOST_PORT=18889
OPENCLAW_PODMAN_PUBLISH_HOST=127.0.0.1
OPENCLAW_PODMAN_NETWORK=openclaw-starter
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_PODMAN_USERNS=keep-id
OPENCLAW_BOARD_IMAGE=python:3.11-slim

# Keep this repo isolated from your main ~/.openclaw state by default.
OPENCLAW_CONFIG_DIR=./.openclaw
OPENCLAW_WORKSPACE_DIR=./.openclaw/workspace
OPENCLAW_SCALE_INSTANCE_ROOT=./.openclaw/instances
OPENCLAW_SCALE_GATEWAY_PORT_START=18789
OPENCLAW_SCALE_BRIDGE_PORT_START=18790
OPENCLAW_SCALE_BOARD_PORT_START=18889
OPENCLAW_SCALE_PORT_STEP=2
OPENCLAW_AUTH_RATE_LIMITED_PROFILE_ROTATIONS=10

# The gateway token is written to OPENCLAW_CONFIG_DIR/.env by init.

# Primary model reference written into openclaw.json.
# Switch to Google Gemini / Gemma 4 later:
# OPENCLAW_MODEL_REF=google/gemma-4-26b-a4b-it
# Switch to Ollama later:
# OPENCLAW_MODEL_REF=ollama/gemma4:e2b
# Switch to OpenRouter instead:
# OPENCLAW_MODEL_REF=openrouter/google/gemma-3n-e2b-it:free
OPENCLAW_MODEL_REF=zai/glm-5.1
OPENCLAW_MODEL_FALLBACKS=zai/glm-5-turbo,zai/glm-5,zai/glm-4.7
# Optional per-instance overrides for the original GLM triad.
# OPENCLAW_MODEL_REF_INSTANCE_001=zai/glm-5.1
# OPENCLAW_MODEL_REF_INSTANCE_002=zai/glm-5-turbo
# OPENCLAW_MODEL_REF_INSTANCE_003=zai/glm-5

# Ollama / gemma4:e2b
# Any placeholder works for local Ollama discovery/auth in OpenClaw.
OLLAMA_API_KEY=ollama-local
# On Windows + Podman, generated runtime config auto-resolves this default to the
# current Podman-machine gateway when `host.containers.internal` is not reachable.
OPENCLAW_OLLAMA_BASE_URL=http://host.containers.internal:11434
# On this Windows + WSL Podman host, 172.27.208.1 was the working value.
OPENCLAW_OLLAMA_MODEL=gemma4:e2b

# OpenRouter
# Only used when OPENCLAW_MODEL_REF points at openrouter/...
OPENCLAW_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Google Gemini / AI Studio
# Only used when OPENCLAW_MODEL_REF points at google/...
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Official OpenClaw key rotation: tries the next key on rate-limit responses.
# GEMINI_API_KEY_1=your-first-project-key
# GEMINI_API_KEY_2=your-second-project-key
# Optional per-instance overrides for scaled pods.
# Keep the existing triad on GLM and add three Gemini agents:
# OPENCLAW_MODEL_REF_INSTANCE_004=google/gemma-4-31b-it
# OPENCLAW_MODEL_REF_INSTANCE_005=google/gemma-3-27b-it
# OPENCLAW_MODEL_REF_INSTANCE_006=google/gemma-4-26b-a4b-it
# Optional: route different Gemini instances to different API keys.
# Note: Gemini API rate limits are applied per project, not per API key.
# GEMINI_API_KEY_INSTANCE_005=your-second-project-key
# GEMINI_API_KEY_INSTANCE_006=your-second-project-key
# OPENCLAW_MATTERMOST_AUTONOMY_MODEL_INSTANCE_001=zai/glm-5.1
# OPENCLAW_MATTERMOST_AUTONOMY_MODEL_INSTANCE_002=zai/glm-5-turbo
# OPENCLAW_MATTERMOST_AUTONOMY_MODEL_INSTANCE_003=zai/glm-5
# OPENCLAW_MATTERMOST_AUTONOMY_MODEL_INSTANCE_004=google/gemma-4-31b-it
# OPENCLAW_MATTERMOST_AUTONOMY_MODEL_INSTANCE_005=google/gemma-3-27b-it
# OPENCLAW_MATTERMOST_AUTONOMY_MODEL_INSTANCE_006=google/gemma-4-26b-a4b-it

# Z.AI
# The bundled OpenClaw Z.AI provider uses ZAI_API_KEY. This base URL is for
# direct OpenAI-compatible helper calls such as Mattermost planner scripts.
OPENCLAW_ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=

# Local Mattermost channel lab.
# The bot tokens and generated passwords live under ./.openclaw/mattermost/state.env after `mattermost seed`.
OPENCLAW_MATTERMOST_ENABLED=false
OPENCLAW_MATTERMOST_DIR=./.openclaw/mattermost
OPENCLAW_MATTERMOST_CONTAINER=mattermost
OPENCLAW_MATTERMOST_IMAGE=docker.io/mattermost/mattermost-preview:11.5.1
OPENCLAW_MATTERMOST_HOST_PORT=8065
OPENCLAW_MATTERMOST_PUBLISH_HOST=127.0.0.1
OPENCLAW_MATTERMOST_BASE_URL=http://mattermost:8065
OPENCLAW_MATTERMOST_SITE_URL=http://localhost:8065
OPENCLAW_MATTERMOST_WEBSOCKET_URL=ws://localhost:8065
OPENCLAW_MATTERMOST_ALLOW_CORS_FROM=http://localhost:8065 http://127.0.0.1:8065
OPENCLAW_MATTERMOST_CHATMODE=oncall
OPENCLAW_MATTERMOST_DM_POLICY=open
OPENCLAW_MATTERMOST_GROUP_POLICY=open
OPENCLAW_MATTERMOST_REPLY_TO_MODE=all
OPENCLAW_MATTERMOST_REQUIRE_MENTION=true
OPENCLAW_MATTERMOST_DANGEROUSLY_ALLOW_PRIVATE_NETWORK=true
OPENCLAW_MATTERMOST_TEAMMATE_NAME_DISPLAY=full_name
OPENCLAW_MATTERMOST_TEAM_NAME=openclaw
OPENCLAW_MATTERMOST_TEAM_DISPLAY_NAME=おーぷんくらう研究室
OPENCLAW_MATTERMOST_TEAM_DESCRIPTION=GLM三席とGemini三席が対話・検証・連携を行うMattermost実験チーム
OPENCLAW_MATTERMOST_CHANNEL_NAME=triad-lab
OPENCLAW_MATTERMOST_CHANNEL_DISPLAY_NAME=ろくせき談話室
OPENCLAW_MATTERMOST_CHANNEL_PURPOSE=GLM三席とGemini三席が雑談・検証・相談を流し込む共有チャンネル
OPENCLAW_MATTERMOST_CHANNEL_HEADER=いおり｜星図航路士｜glm-5.1 / つむぎ｜夢写本師｜glm-5-turbo / さく｜痕跡鑑識官｜glm-5 / るり｜信号地図師｜gemma-4-31b-it / ひびき｜拍子調律師｜gemma-3-27b-it / かなえ｜検証編み手｜gemma-4-26b-a4b-it
OPENCLAW_MATTERMOST_AUTONOMY_ENABLED=false
OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL=20m
OPENCLAW_MATTERMOST_AUTONOMY_LIGHT_CONTEXT=true
OPENCLAW_MATTERMOST_AUTONOMY_ISOLATED_SESSION=true
# Optional per-character cadence overrides.
# If omitted, `mattermost lounge enable` seeds defaults from the base interval.
# OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL_INSTANCE_001=20m
# OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL_INSTANCE_002=10m
# OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL_INSTANCE_003=45m
# OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL_INSTANCE_004=30m
# OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL_INSTANCE_005=15m
# OPENCLAW_MATTERMOST_AUTONOMY_INTERVAL_INSTANCE_006=60m
# Optional heartbeat-only model override for Mattermost autonomy.
# Leave blank to auto-pick the current primary model.
OPENCLAW_MATTERMOST_AUTONOMY_MODEL=
OPENCLAW_MATTERMOST_ADMIN_USERNAME=ocadmin
OPENCLAW_MATTERMOST_ADMIN_EMAIL=ocadmin@openclaw.local
OPENCLAW_MATTERMOST_OPERATOR_USERNAME=operator
OPENCLAW_MATTERMOST_OPERATOR_EMAIL=operator@openclaw.local

# Add only the provider keys you actually use.
OPENAI_API_KEY=
